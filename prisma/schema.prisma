generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS — CRM DOMAIN
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CLIENT
  VIEWER
}

enum RecordType {
  LEAD
  CLIENT
  PROSPECT
}

enum OrgStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  CHURNED
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  EMAIL_CAMPAIGN
  COLD_OUTREACH
  PAID_ADS
  ORGANIC_SEARCH
  AI_AGENT
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATING
  WON
  LOST
  UNQUALIFIED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PAUSED
}

enum DocCategory {
  CONTRACT
  PROPOSAL
  REPORT
  INVOICE
  STRATEGY
  CREATIVE
  LEGAL
  OTHER
}

enum DocStatus {
  DRAFT
  REVIEW
  APPROVED
  SENT                 // sent to client awaiting signature
  AWAITING_COUNTERSIGN // client signed, admin to countersign
  COUNTERSIGNED        // both parties signed
  SIGNED               // legacy / single-party signed
  ARCHIVED
  VOIDED
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum ReportType {
  WEEKLY
  MONTHLY
  QUARTERLY
  CAMPAIGN
  CUSTOM
}

enum ReportStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  AWAITING_APPROVAL
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// CRM DOMAIN MODELS
// ─────────────────────────────────────────────

model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  fullName  String?  @map("full_name")
  avatarUrl String?  @map("avatar_url")
  role      UserRole @default(CLIENT)
  phone     String?
  timezone  String?  @default("UTC")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?       @map("organization_id") @db.Uuid

  sentMessages   Message[]       @relation("SentMessages")
  notifications  Notification[]
  auditLogs      AuditLog[]
  appointments   Appointment[]
  reportComments ReportComment[]
  createdLeads   Lead[]          @relation("LeadCreatedBy")
  clientRequests ClientRequest[]

  @@map("profiles")
}

model Organization {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  slug             String    @unique
  status           OrgStatus @default(ACTIVE)
  website          String?
  industry         String?
  logoUrl          String?   @map("logo_url")
  phone            String?
  address          String?
  city             String?
  state            String?
  country          String?
  notes            String?   @db.Text
  monthlyBudget    Decimal?  @map("monthly_budget") @db.Decimal(12, 2)
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  members        Profile[]
  leads          Lead[]
  documents      Document[]
  proposals      Proposal[]
  invoices       Invoice[]
  reports        Report[]
  assets         Asset[]
  requests       ClientRequest[]
  onboarding     OnboardingPacket?
  emailSequences EmailSequenceEnrollment[]
  qrCodes        QRCode[]
  appointments   Appointment[]

  @@map("organizations")
}

model Lead {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName      String     @map("first_name")
  lastName       String     @map("last_name")
  email          String?
  phone          String?
  company        String?
  jobTitle       String?    @map("job_title")
  website        String?
  source         LeadSource @default(OTHER)
  status         LeadStatus @default(NEW)
  priority       Priority   @default(MEDIUM)
  notes          String?    @db.Text
  estimatedValue Decimal?   @map("estimated_value") @db.Decimal(12, 2)
  closedAt       DateTime?  @map("closed_at")
  agentLeadId    String?    @map("agent_lead_id") @db.Uuid

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?       @map("organization_id") @db.Uuid

  createdBy   Profile? @relation("LeadCreatedBy", fields: [createdById], references: [id])
  createdById String?  @map("created_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([source])
  @@map("leads")
}

model OnboardingPacket {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String           @unique @map("organization_id") @db.Uuid
  status         OnboardingStatus @default(NOT_STARTED)
  startedAt      DateTime?        @map("started_at")
  completedAt    DateTime?        @map("completed_at")
  dueDate        DateTime?        @map("due_date")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  steps OnboardingStep[]

  @@map("onboarding_packets")
}

model OnboardingStep {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  packet      OnboardingPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
  packetId    String           @map("packet_id") @db.Uuid
  title       String
  description String?          @db.Text
  order       Int
  isRequired  Boolean          @default(true) @map("is_required")
  completedAt DateTime?        @map("completed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([packetId, order])
  @@map("onboarding_steps")
}

model DocumentTemplate {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  category  DocCategory
  content   String      @db.Text
  variables Json        @default("[]")
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  documents Document[]

  @@map("document_templates")
}

model Document {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  category       DocCategory
  status         DocStatus        @default(DRAFT)
  content        String?          @db.Text
  fileUrl        String?          @map("file_url")
  fileSize       Int?             @map("file_size")
  mimeType       String?          @map("mime_type")
  signedAt       DateTime?        @map("signed_at")
  signatureData  String?          @map("signature_data") @db.Text
  expiresAt      DateTime?        @map("expires_at")
  publicToken    String?          @unique @default(dbgenerated("gen_random_uuid()::text")) @map("public_token")
  viewedAt       DateTime?        @map("viewed_at")
  signerName     String?          @map("signer_name")
  signerEmail    String?          @map("signer_email")
  pdfUrl         String?          @map("pdf_url")

  organization   Organization?    @relation(fields: [organizationId], references: [id])
  organizationId String?          @map("organization_id") @db.Uuid

  template       DocumentTemplate? @relation(fields: [templateId], references: [id])
  templateId     String?           @map("template_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("documents")
}

model Proposal {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String
  status        ProposalStatus @default(DRAFT)
  content       Json
  totalValue    Decimal        @map("total_value") @db.Decimal(12, 2)
  validUntil    DateTime?      @map("valid_until")
  publicToken   String         @unique @default(dbgenerated("gen_random_uuid()::text")) @map("public_token")
  viewedAt      DateTime?      @map("viewed_at")
  acceptedAt    DateTime?      @map("accepted_at")
  rejectedAt    DateTime?      @map("rejected_at")
  signatureData String?        @map("signature_data") @db.Text
  notes         String?        @db.Text
  pdfUrl        String?        @map("pdf_url")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("proposals")
}

model Invoice {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceNumber         String        @unique @map("invoice_number")
  status                InvoiceStatus @default(DRAFT)
  subtotal              Decimal       @db.Decimal(12, 2)
  tax                   Decimal       @default(0) @db.Decimal(12, 2)
  total                 Decimal       @db.Decimal(12, 2)
  currency              String        @default("USD")
  dueDate               DateTime?     @map("due_date")
  paidAt                DateTime?     @map("paid_at")
  stripePaymentIntentId String?       @unique @map("stripe_payment_intent_id")
  notes                 String?       @db.Text
  lineItems             Json          @default("[]") @map("line_items")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("invoices")
}

model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content        String   @db.Text
  isRead         Boolean  @default(false) @map("is_read")
  readAt         DateTime? @map("read_at")
  metadata       Json     @default("{}")

  sender         Profile  @relation("SentMessages", fields: [senderId], references: [id])
  senderId       String   @map("sender_id") @db.Uuid

  organizationId String?  @map("organization_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([senderId])
  @@index([organizationId])
  @@map("messages")
}

model Report {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  type        ReportType
  status      ReportStatus @default(DRAFT)
  content     Json
  period      String?
  publishedAt DateTime?    @map("published_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  comments ReportComment[]

  @@index([organizationId])
  @@map("reports")
}

model ReportComment {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content  String @db.Text

  report   Report  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId String  @map("report_id") @db.Uuid

  author   Profile @relation(fields: [authorId], references: [id])
  authorId String  @map("author_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@map("report_comments")
}

model Asset {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  fileUrl      String   @map("file_url")
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type")
  folder       String   @default("general")
  tags         String[] @default([])
  description  String?  @db.Text

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?       @map("organization_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("assets")
}

model ClientRequest {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String        @db.Text
  status      RequestStatus @default(OPEN)
  priority    Priority      @default(MEDIUM)
  resolvedAt  DateTime?     @map("resolved_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String       @map("organization_id") @db.Uuid

  submittedBy   Profile @relation(fields: [submittedById], references: [id])
  submittedById String  @map("submitted_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("client_requests")
}

model EmailSequence {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  steps       EmailSequenceStep[]
  enrollments EmailSequenceEnrollment[]

  @@map("email_sequences")
}

model EmailSequenceStep {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sequence   EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  sequenceId String        @map("sequence_id") @db.Uuid
  subject    String
  htmlBody   String        @map("html_body") @db.Text
  delayDays  Int           @default(0) @map("delay_days")
  order      Int
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@index([sequenceId, order])
  @@map("email_sequence_steps")
}

model EmailSequenceEnrollment {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sequence       EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  sequenceId     String        @map("sequence_id") @db.Uuid
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId String        @map("organization_id") @db.Uuid
  currentStep    Int           @default(0) @map("current_step")
  completedAt    DateTime?     @map("completed_at")
  unsubscribedAt DateTime?     @map("unsubscribed_at")
  enrolledAt     DateTime      @default(now()) @map("enrolled_at")

  @@index([sequenceId])
  @@index([organizationId])
  @@map("email_sequence_enrollments")
}

model QRCode {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  code           String  @unique
  destinationUrl String  @map("destination_url")
  isActive       Boolean @default(true) @map("is_active")
  totalScans     Int     @default(0) @map("total_scans")

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?       @map("organization_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scans QRScan[]

  @@map("qr_codes")
}

model QRScan {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  qrCode    QRCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  qrCodeId  String   @map("qr_code_id") @db.Uuid
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  country   String?
  city      String?
  scannedAt DateTime @default(now()) @map("scanned_at")

  @@index([qrCodeId])
  @@map("qr_scans")
}

model SiteContent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  section   String   @unique
  content   Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_content")
}

model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String
  body      String    @db.Text
  type      String
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  href      String?
  metadata  Json      @default("{}")

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String  @map("profile_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([profileId, isRead])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")

  actor   Profile? @relation(fields: [actorId], references: [id])
  actorId String?  @map("actor_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Appointment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?  @db.Text
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  location    String?
  meetingUrl  String?  @map("meeting_url")
  isConfirmed Boolean  @default(false) @map("is_confirmed")

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?       @map("organization_id") @db.Uuid

  profile   Profile? @relation(fields: [profileId], references: [id])
  profileId String?  @map("profile_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("appointments")
}

// ─────────────────────────────────────────────
// AGENT DOMAIN MODELS
// ─────────────────────────────────────────────

enum AgentCampaignStatus {
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum AgentLeadStatus {
  DISCOVERED
  ANALYZING
  QUALIFIED
  DISQUALIFIED
  EMAIL_FOUND
  EMAILED
  REPLIED_POSITIVE
  REPLIED_NEGATIVE
  REPLIED_UNSUBSCRIBE
  BOUNCED
  CONVERTED
  FAILED
}

model AgentCampaign {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  niche          String
  targetCount    Int                 @map("target_count")
  status         AgentCampaignStatus @default(QUEUED)
  settings       Json                @default("{}")
  progress       Int                 @default(0)
  totalProcessed Int                 @default(0) @map("total_processed")
  totalEmailed   Int                 @default(0) @map("total_emailed")
  totalFailed    Int                 @default(0) @map("total_failed")
  enableAiVision Boolean             @default(true) @map("enable_ai_vision")
  startedAt      DateTime?           @map("started_at")
  completedAt    DateTime?           @map("completed_at")
  failedAt       DateTime?           @map("failed_at")
  errorMessage   String?             @map("error_message")
  createdBy      String?             @map("created_by") @db.Uuid
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  leads       AgentLead[]
  emailLogs   AgentEmailLog[]
  checkpoints AgentCampaignCheckpoint[]

  @@map("agent_campaigns")
}

model AgentLead {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId          String          @map("campaign_id") @db.Uuid
  campaign            AgentCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  businessName        String          @map("business_name")
  website             String?
  placesId            String?         @map("places_id")
  phone               String?
  email               String?
  address             String?
  city                String?
  state               String?
  country             String?
  websiteScore        Int?            @map("website_score")
  websiteAnalysis     Json?           @map("website_analysis")
  screenshotUrl       String?         @map("screenshot_url")
  emailSource         String?         @map("email_source")
  outreachStatus      AgentLeadStatus @default(DISCOVERED) @map("outreach_status")
  replyClassification String?         @map("reply_classification")
  convertedAt         DateTime?       @map("converted_at")
  crmLeadId           String?         @map("crm_lead_id") @db.Uuid
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  emailLogs AgentEmailLog[]

  @@index([campaignId])
  @@index([outreachStatus])
  @@map("agent_leads")
}

model AgentEmailLog {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId      String    @map("campaign_id") @db.Uuid
  campaign        AgentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadId          String    @map("lead_id") @db.Uuid
  lead            AgentLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequence        Int       @default(0)
  subject         String
  htmlBody        String    @map("html_body") @db.Text
  resendMessageId String?   @unique @map("resend_message_id")
  spamScore       Float?    @map("spam_score")
  sentAt          DateTime? @map("sent_at")
  deliveredAt     DateTime? @map("delivered_at")
  openedAt        DateTime? @map("opened_at")
  clickedAt       DateTime? @map("clicked_at")
  bouncedAt       DateTime? @map("bounced_at")
  complainedAt    DateTime? @map("complained_at")
  unsubscribedAt  DateTime? @map("unsubscribed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  events AgentEmailEvent[]

  @@index([resendMessageId])
  @@map("agent_email_logs")
}

model AgentEmailEvent {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  emailLogId String        @map("email_log_id") @db.Uuid
  emailLog   AgentEmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)
  eventType  String        @map("event_type")
  rawPayload Json          @map("raw_payload")
  receivedAt DateTime      @default(now()) @map("received_at")

  @@map("agent_email_events")
}

model AgentAuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String?  @map("campaign_id") @db.Uuid
  leadId     String?  @map("lead_id") @db.Uuid
  action     String
  details    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([campaignId])
  @@map("agent_audit_logs")
}

model AgentCampaignCheckpoint {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String        @unique @map("campaign_id") @db.Uuid
  campaign   AgentCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  state      Json
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@map("agent_campaign_checkpoints")
}

model AgentGlobalUnsubscribe {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("agent_global_unsubscribes")
}

model AgentGlobalHardBounce {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("agent_global_hard_bounces")
}

model AgentTenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  config    Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("agent_tenants")
}
